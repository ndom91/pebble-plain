{
  "name": "watchapp",
  "author": "ndom91",
  "version": "0.0.2",
  "keywords": [
    "pebble-app"
  ],
  "private": true,
  "dependencies": {
    "@moddable/pebbleproxy": "^0.1.8",
    "@rebble/clay": "^1.0.10"
  },
  "scripts": {
    "pebble:config": "pebble emu-app-config",
    "pebble:install-mobile": "pebble install --phone 10.0.1.34",
    "pebble:dev": "pebble build && pebble install --emulator emery --logs"
  },
  "pebble": {
    "displayName": "Plain",
    "uuid": "845c1b8a-3ed8-4d8a-9f2a-816bcf794777",
    "projectType": "moddable",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "capabilities": [
      "configurable"
    ],
    "targetPlatforms": [
      "emery",
      "gabbro"
    ],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": [
      "THREADS_START",
      "THREAD_LINE",
      "THREADS_DONE",
      "THREAD_ID",
      "THREAD_DETAIL_START",
      "THREAD_DETAIL_LINE",
      "THREAD_DETAIL_DONE",
      "THREAD_DETAIL_ERROR",
      "ERROR",
      "PLAIN_API_KEY",
      "CLEAR_API_KEY"
    ],
    "resources": {
      "media": [
        {
          "type": "bitmap",
          "name": "MENU_ICON",
          "file": "images/menu-icon.png",
          "menuIcon": true
        }
      ]
    }
  }
}
