{
  "name": "plain-pebble",
  "description": "View Plain TODO support threads, details, and recent messages on Pebble.",
  "author": "ndom91",
  "version": "1.0.0",
  "keywords": [
    "pebble-app",
    "plain",
    "support",
    "threads"
  ],
  "private": true,
  "dependencies": {
    "@rebble/clay": "^1.0.10"
  },
  "scripts": {
    "pebble:config": "BROWSER='open -a \"Google Chrome\" %s' pebble emu-app-config",
    "pebble:install-mobile": "pebble install --phone 10.0.1.34",
    "pebble:dev": "pebble build && pebble install --emulator emery --logs"
  },
  "pebble": {
    "displayName": "Plain",
    "uuid": "845c1b8a-3ed8-4d8a-9f2a-816bcf794777",
    "projectType": "native",
    "sdkVersion": "3",
    "enableMultiJS": true,
    "capabilities": [
      "configurable"
    ],
    "targetPlatforms": [
      "emery",
      "gabbro"
    ],
    "watchapp": {
      "watchface": false
    },
    "messageKeys": [
      "THREADS",
      "THREAD_ID",
      "THREAD_DETAIL",
      "THREAD_DETAIL_ERROR",
      "ERROR",
      "PLAIN_API_KEY",
      "CLEAR_API_KEY"
    ],
    "resources": {
      "media": [
        {
          "type": "bitmap",
          "name": "MENU_ICON",
          "file": "images/menu-icon.png",
          "menuIcon": true
        }
      ]
    }
  }
}
